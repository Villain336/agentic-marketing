# ═══════════════════════════════════════════════════════════════════════════════
# Supervisor Backend — Environment Variables
# 82 tools across 22 categories. All keys optional — tools gracefully degrade.
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Providers (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT=120

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_FAST_MODEL=gemini-2.0-flash-lite
GOOGLE_TIMEOUT=120

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Web Search ───────────────────────────────────────────────────────────────
SERPER_API_KEY=              # serper.dev — web search (free: 2500/mo)

# ── Prospecting & Enrichment ─────────────────────────────────────────────────
APOLLO_API_KEY=              # apollo.io — contacts, enrichment (free: 10k credits/mo)
HUNTER_API_KEY=              # hunter.io — email verification
CLEARBIT_API_KEY=            # clearbit.com — company + person enrichment
BOMBORA_API_KEY=             # bombora.com — buyer intent signals

# ── Voice & SMS (cold calls, follow-ups, voicemail drops) ────────────────────
BLAND_API_KEY=               # bland.ai — AI phone calls ($0.07/min)
VAPI_API_KEY=                # vapi.ai — AI voice agents
VAPI_PHONE_ID=               # vapi.ai phone number ID
TWILIO_ACCOUNT_SID=          # twilio.com — calls + SMS
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=         # E.164 format: +1234567890

# ── LinkedIn Automation ──────────────────────────────────────────────────────
PHANTOMBUSTER_API_KEY=       # phantombuster.com — LinkedIn messaging
PHANTOMBUSTER_LINKEDIN_AGENT_ID=

# ── Email (SendGrid) ────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# ── Email Warmup ─────────────────────────────────────────────────────────────
INSTANTLY_API_KEY=           # instantly.ai — email warmup & deliverability

# ── Social Media ─────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_ACCESS_TOKEN=
TWITTER_BEARER_TOKEN=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_AD_TOKEN=           # LinkedIn Marketing API access token

INSTAGRAM_BUSINESS_ID=       # Meta Business Suite Instagram account ID

BUFFER_API_KEY=              # buffer.com — social scheduling
PRODUCTHUNT_TOKEN=           # producthunt.com — community monitoring

# ── SEO & Content ────────────────────────────────────────────────────────────
DATAFORSEO_LOGIN=            # dataforseo.com — keyword research, backlinks
DATAFORSEO_PASSWORD=
SEMRUSH_API_KEY=             # semrush.com — keyword research (alternative)

# ── Image Generation ─────────────────────────────────────────────────────────
OPENAI_IMAGE_KEY=            # OpenAI DALL-E 3 (or reuse OPENAI_API_KEY)
REPLICATE_API_KEY=           # replicate.com — Flux, Stable Diffusion
FAL_API_KEY=                 # fal.ai — fast image generation

# ── CMS Publishing ───────────────────────────────────────────────────────────
WORDPRESS_URL=               # e.g. https://mysite.com
WORDPRESS_USER=
WORDPRESS_APP_PASSWORD=      # WordPress Application Password
GHOST_URL=                   # e.g. https://mysite.ghost.io
GHOST_ADMIN_KEY=             # Ghost Admin API key (id:secret format)
WEBFLOW_API_KEY=
WEBFLOW_BLOG_COLLECTION_ID=

# ── Plagiarism Check ─────────────────────────────────────────────────────────
COPYSCAPE_USER=
COPYSCAPE_API_KEY=

# ── Ads ──────────────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=
META_PIXEL_ID=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ANALYTICS_ID=         # GA4 measurement ID (G-XXXXXXXXXX)

# ── Deployment & DNS ─────────────────────────────────────────────────────────
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY=    # R2 object storage for brand assets
CLOUDFLARE_R2_SECRET_KEY=
CLOUDFLARE_R2_BUCKET=
GODADDY_API_KEY=             # godaddy.com — domain registration
GODADDY_API_SECRET=

# ── Analytics & Monitoring ───────────────────────────────────────────────────
PLAUSIBLE_API_KEY=           # plausible.io — privacy-friendly analytics
GOOGLE_ANALYTICS_API_KEY=    # GA4 Data API (service account token)
GOOGLE_SEARCH_CONSOLE_KEY=   # GSC API access token
GOOGLE_PSI_API_KEY=          # PageSpeed Insights API key (optional, works without)
BETTERUPTIME_API_KEY=        # betteruptime.com — uptime monitoring
UPTIMEROBOT_API_KEY=         # uptimerobot.com — uptime monitoring (alternative)
BROWSERLESS_API_KEY=         # browserless.io — screenshots, PDF generation
SCREENSHOTONE_API_KEY=       # screenshotone.com — screenshots (alternative)

# ── CRM ──────────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=

# ── Calendar ─────────────────────────────────────────────────────────────────
CALCOM_API_KEY=

# ── Legal & Documents ────────────────────────────────────────────────────────
DOCUSIGN_API_KEY=            # docusign.com — e-signatures
PANDADOC_API_KEY=            # pandadoc.com — e-signatures (alternative)

# ── Surveys ──────────────────────────────────────────────────────────────────
TYPEFORM_API_KEY=            # typeform.com — surveys and forms

# ── Market Research ──────────────────────────────────────────────────────────
SIMILARWEB_API_KEY=          # similarweb.com — website traffic data
BUILTWITH_API_KEY=           # builtwith.com — tech stack detection

# ── Newsletter ESPs (choose one) ────────────────────────────────────────────
CONVERTKIT_API_KEY=          # convertkit.com
MAILCHIMP_API_KEY=           # mailchimp.com (format: key-dc)
BEEHIIV_API_KEY=             # beehiiv.com
BEEHIIV_PUBLICATION_ID=

# ── Messaging & Alerts ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=      # Your Telegram chat ID for alerts
SLACK_BOT_TOKEN=
OWNER_EMAIL=                 # Fallback email for supervisor alerts

# ── App Settings ─────────────────────────────────────────────────────────────
DEBUG=false
MAX_AGENT_ITERATIONS=25
MAX_AGENT_RUNTIME=300
