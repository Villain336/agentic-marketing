# ═══════════════════════════════════════════════════════════════════════════════
# Supervisor Backend — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ── LLM Providers (at least one required) ─────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_TIMEOUT=120

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=120

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GOOGLE_FAST_MODEL=gemini-2.0-flash-lite
GOOGLE_TIMEOUT=120

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Tool API Keys ─────────────────────────────────────────────────────────────
SERPER_API_KEY=          # serper.dev — web search (free: 2500 searches)
APOLLO_API_KEY=          # apollo.io — company/contact enrichment (free: 10k credits/mo)
HUNTER_API_KEY=          # hunter.io — email verification

# ── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_WEBHOOK_SECRET=

# ── Social Media ──────────────────────────────────────────────────────────────
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Ads ───────────────────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=

GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=

# ── Site Deployment ───────────────────────────────────────────────────────────
VERCEL_TOKEN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# ── CRM ───────────────────────────────────────────────────────────────────────
HUBSPOT_API_KEY=

# ── Calendar ──────────────────────────────────────────────────────────────────
CALCOM_API_KEY=

# ── Messaging ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

# ── App Settings ──────────────────────────────────────────────────────────────
DEBUG=false
MAX_AGENT_ITERATIONS=25
MAX_AGENT_RUNTIME=300
